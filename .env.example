# --- dbt-duckdb (project root: repo/medallion/) ---
# Primary DuckDB file where dbt creates models (views/tables). Paths are
# relative to the directory you run `dbt` from (use: cd medallion && dbt run).
DBT_DUCKDB_PATH=dev.duckdb
# Bronze/raw DuckDB with source tables (air_quality, vehicle_speed, …).
DBT_BRONZE_DUCKDB_PATH=../raw/raw_data.duckdb
# Optional: make dbt use repo-local profiles.yml
# DBT_PROFILES_DIR=.

# --- Superset admin bootstrap ---
SUPERSET_SECRET_KEY=please-change-me-in-production
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
