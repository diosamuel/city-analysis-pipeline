BASE_KEMENLH_API=https://ispu.kemenlh.go.id/apimobile/v1/getStations
BASE_BMKG_API=https://api.bmkg.go.id/publik/prakiraan-cuaca
BASE_NOMINATIM_API=https://nominatim.openstreetmap.org/reverse

BASE_CCTV_CHART1_API=https://apace-ai.com/generateChart1Data/
BASE_CCTV_CHART2_API=https://apace-ai.com/generateChart2Data/
BASE_CCTV_CHART3_API=https://apace-ai.com/generateChart3Data/

# --- dbt-duckdb (project root: repo/medallion/) ---
# Primary DuckDB file where dbt creates models (views/tables). Paths are
# relative to the directory you run `dbt` from (use: cd medallion && dbt run).
DBT_DUCKDB_PATH=dev.duckdb
# Bronze/raw DuckDB with source tables (air_quality, vehicle_speed, …).
DBT_BRONZE_DUCKDB_PATH=../raw/raw_data.duckdb
# Optional: make dbt use repo-local profiles.yml
# DBT_PROFILES_DIR=.

# --- Docker Compose: Kestra (postgres uses same password in jdbc URL) ---
KESTRA_POSTGRES_PASSWORD=k3str4

# --- Docker Compose: Superset metadata DB ---
SUPERSET_DATABASE_DB=superset
SUPERSET_DATABASE_USER=superset
SUPERSET_DATABASE_PASSWORD=superset

# --- Superset → Google BigQuery (Docker) ---
# Copy your service account JSON into .gcp/ (e.g. .gcp/bigquery-sa.json). Folder is mounted at /etc/gcp in the superset container.
GCP_SA_FILENAME=bigquery-sa.json
# Optional hints for SQLAlchemy URI in Superset UI: bigquery://GCP_PROJECT_ID/GCP_BIGQUERY_DATASET
GCP_PROJECT_ID=your-gcp-project-id
GCP_BIGQUERY_DATASET=dbt_dio

# --- Superset admin bootstrap ---
SUPERSET_SECRET_KEY=please-change-me-in-production
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
